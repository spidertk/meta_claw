{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "knowledge/contracts/snapshot-store.schema.json",
  "title": "SnapshotRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "space_id",
    "snapshot_id",
    "source_id",
    "content_fingerprint",
    "captured_at",
    "units",
    "scan_status",
    "unit_limit",
    "included_unit_count",
    "scan_batch_count",
    "next_scan_cursor"
  ],
  "properties": {
    "space_id": {
      "type": "string"
    },
    "snapshot_id": {
      "type": "string"
    },
    "source_id": {
      "type": "string"
    },
    "content_fingerprint": {
      "type": "string"
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "units": {
      "type": "array",
      "items": {
        "$ref": "./unit-ref.schema.json"
      }
    },
    "scan_status": {
      "type": "string",
      "enum": [
        "complete",
        "partial",
        "truncated",
        "failed"
      ]
    },
    "unit_limit": {
      "type": "integer",
      "minimum": 0
    },
    "included_unit_count": {
      "type": "integer",
      "minimum": 0
    },
    "scan_batch_count": {
      "type": "integer",
      "minimum": 0
    },
    "next_scan_cursor": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
